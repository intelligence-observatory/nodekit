NODEKIT_SERVER_BOOTSTRAP_ADMIN_USERNAME=admin
NODEKIT_SERVER_BOOTSTRAP_ADMIN_API_TOKEN=dev-token
NODEKIT_SERVER_PUBLIC_BASE_URL=http://localhost:8000
NODEKIT_SERVER_CREATE_SCHEMA_ON_STARTUP=true
# SQLite is the local default when NODEKIT_SERVER_DATABASE_URL is unset.
# NODEKIT_SERVER_DATABASE_URL=sqlite:///./nodekit-server.db
# PostgreSQL example:
# NODEKIT_SERVER_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
NODEKIT_SERVER_ASSET_STORE_BACKEND=filesystem

# S3 Asset storage, when NODEKIT_SERVER_ASSET_STORE_BACKEND=s3:
# NODEKIT_SERVER_S3_BUCKET_NAME=my-nodekit-assets
# NODEKIT_SERVER_S3_REGION_NAME=us-east-1
# NODEKIT_SERVER_S3_PREFIX=assets
# NODEKIT_SERVER_S3_PUBLIC_BASE_URL=https://my-nodekit-assets.s3.us-east-1.amazonaws.com
# NODEKIT_SERVER_S3_ENDPOINT_URL=
